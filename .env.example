# ========================================
# Docker Images
# ========================================
RETH_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-reth:v1.11.0
NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.16.7

# ========================================
# Reth Flags (flag-aligned env used by reth-entrypoint.sh)
# ========================================
RETH_DATADIR=/data
RETH_HTTP_API=admin,net,eth,web3,debug,trace,txpool,miner
RETH_WS_API=net,eth,web3,debug,trace,txpool,miner
RETH_ROLLUP_SEQUENCER_HTTP=https://rpc.example.com
RETH_BOOTNODES=enode://replace-with-reth-bootnode@host:30303
# RETH_VERBOSITY=-vvv
# Optional reth extension point for chain-specific extra flags.
# Platform-generated .env should leave room for this field even if most chains keep it empty.
# Example:
# RETH_EXTRA_ARGS="--flashblocks-url=ws://xxx --flashblock-consensus"
# RETH_EXTRA_ARGS=

# ========================================
# Chain Source: choose one
# ========================================
# Superchain:
# RETH_CHAIN=base
# OP_NODE_NETWORK=base-mainnet
#
# Note:
# Superchain mode requires RETH_CHAIN explicitly.
# RETH_CHAIN and OP_NODE_NETWORK do not have to be identical.
# Some chains use different identifiers for reth and op-node.

# Non-superchain:
RETH_CHAIN=/data/genesis.json
GENESIS_URL=https://operator-public.s3.us-west-2.amazonaws.com/chain/mainnet/genesis.json
OP_NODE_ROLLUP_CONFIG=/data/rollup.json
ROLLUP_CONFIG_URL=https://operator-public.s3.us-west-2.amazonaws.com/chain/mainnet/rollup.json

# ========================================
# OP-Node Environment
# ========================================
OP_NODE_L1_ETH_RPC=https://ethereum-rpc.publicnode.com
OP_NODE_L1_RPC_KIND=standard
OP_NODE_L1_TRUST_RPC=true
OP_NODE_L1_RPC_RATE_LIMIT=1000
OP_NODE_SYNCMODE=consensus-layer
OP_NODE_VERIFIER_L1_CONFS=15
OP_NODE_RPC_ADDR=0.0.0.0
OP_NODE_P2P_PRIV_PATH=/data/p2p_priv.txt
OP_NODE_P2P_STATIC=/dns/replace-with-fullnode-static-peer/tcp/9003/p2p/16Uiu2...
OP_NODE_LOG_LEVEL=INFO
OP_NODE_SEQUENCER_ENABLED=false

# ========================================
# Data Availability: choose one
# ========================================
# Beacon mode:
OP_NODE_L1_BEACON=https://ethereum-beacon-api.publicnode.com

# ALTDA mode:
# OP_NODE_L1_BEACON_IGNORE=true
# OP_NODE_ALTDA_ENABLED=true
# OP_NODE_ALTDA_DA_SERVER=https://your-da-server.com
# OP_NODE_ALTDA_DA_SERVICE=true

# Optional advanced admin API for ops such as admin_resetDerivationPipeline.
# Not required for normal fullnode RPC usage.
# OP_NODE_RPC_ENABLE_ADMIN=true
#
# Optional extra flags for op-node
# OP_NODE_EXTRA_FLAGS=

# ========================================
# Official Op-Node Envs Currently Set By This Repo
# ========================================
# These are official upstream op-node env names you would also see via `op-node --help`.
# This repo currently sets them in scripts/node-entrypoint.sh instead of exposing them
# as first-class `.env` settings.
#
# OP_NODE_L2_ENGINE_RPC=http://reth:8551
# OP_NODE_L2_ENGINE_AUTH=/data/jwt.txt
# OP_NODE_L2_ENGINE_KIND=reth
# OP_NODE_SAFEDB_PATH=/data/safedb
# OP_NODE_METRICS_ENABLED=true
# OP_NODE_METRICS_ADDR=0.0.0.0
# OP_NODE_METRICS_PORT=7300
# OP_NODE_RPC_PORT=9545
# OP_NODE_P2P_LISTEN_IP=0.0.0.0
# OP_NODE_P2P_LISTEN_TCP_PORT=9003
# OP_NODE_P2P_LISTEN_UDP_PORT=9003
# OP_NODE_P2P_DISCOVERY_PATH=/data/p2p_discovery
# OP_NODE_P2P_PEERSTORE_PATH=/data/p2p_peerstore

# Ports currently live in docker-compose.yml.
# If you need different exposed host ports, edit docker-compose.yml directly.

# ========================================
# Quick Start
# ========================================
# 1. Copy one of examples/modes/*.env to .env, or edit this file directly.
# 2. Generate JWT: openssl rand -hex 32 > jwt.txt
# 3. Start: docker compose up -d
# 4. Verify: ./scripts/check-sync.sh
