# ========================================
# Docker Images
# ========================================
GETH_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-geth:v1.101411.0
NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.10.2

# ========================================
# GETH Configuration
# ========================================
# Sync and GC modes
GETH_SYNCMODE=full
GETH_GCMODE=archive

# Rollup configuration
GETH_ROLLUP_SEQUENCERHTTP=https://rpc.example.com

# HTTP and WebSocket API modules (optional - defaults provided)
# GETH_HTTP_API=web3,eth,txpool,net,engine,debug,miner,admin
# GETH_WS_API=web3,eth,txpool,net,engine,debug,miner,admin

# Ports Configuration
GETH_HTTP_PORT=8545
GETH_WS_PORT=8546
GETH_AUTHRPC_PORT=8551
GETH_METRICS_PORT=6060
GETH_P2P_PORT=30303

# Static nodes for P2P
GETH_STATICNODES='["enode://...@host:port"]'

# Superchain Configuration (Optional - only for Superchain networks)
# GETH_OP_NETWORK=chain-mainnet
# GETH_ROLLUP_SUPERCHAIN_UPGRADES=false

# ========================================
# OP-NODE Configuration
# ========================================
# L1 Configuration
OP_NODE_L1_ETH_RPC=https://ethereum-rpc.publicnode.com
OP_NODE_L1_RPC_KIND=standard
OP_NODE_L1_TRUST_RPC=true

# L1 Beacon API (Required unless using ALTDA)
# OP_NODE_L1_BEACON=https://ethereum-beacon-api.publicnode.com

# Sync Mode Configuration
OP_NODE_SYNCMODE=execution-layer

# Ports Configuration
OP_NODE_RPC_PORT=9545
OP_NODE_METRICS_PORT=7300
OP_NODE_P2P_TCP_PORT=9003
OP_NODE_P2P_UDP_PORT=9003

# P2P Static Nodes
OP_NODE_P2P_STATIC=

# Extra flags for op-node (optional - for advanced users)
# Example: OP_NODE_EXTRA_FLAGS="--log.level=debug --log.format=json"
# OP_NODE_EXTRA_FLAGS=

# Rollup Config (MUTUALLY EXCLUSIVE - choose ONE)
# OPTION 1: Superchain Network Name (for Superchain networks)
# Use this if your chain is part of the Superchain
# OP_NODE_NETWORK=chain-mainnet

# OPTION 2: Custom Rollup Config URL (for non-Superchain networks)
# Use this for standard OP Stack chains not in the Superchain
# The startup script will download this to /data/rollup.json
ROLLUP_CONFIG_URL=https://operator-public.s3.us-west-2.amazonaws.com/chain/mainnet/rollup.json

# ========================================
# ALTDA Configuration (Optional - for EigenDA/Avail chains)
# ========================================
# If using ALTDA, uncomment and configure these variables
# The startup script will automatically set OP_NODE_L1_BEACON_IGNORE=true
# OP_NODE_ALTDA_ENABLED=true
# OP_NODE_ALTDA_DA_SERVER=https://your-da-server.com
# OP_NODE_ALTDA_DA_SERVICE=true  # Only needed for specific chains like openledger

# ========================================
# Path Configuration
# ========================================
# Data directory paths
GETH_DATADIR=/data
OP_NODE_DATADIR=/data

# P2P Private Key Path
OP_NODE_P2P_PRIV_PATH=/data/p2p_priv.txt

# ========================================
# Helper Variables (for startup scripts only)
# ========================================
# These variables are used by the startup scripts for conditional logic
# They are NOT directly used by geth or op-node binaries

# Genesis Initialization
GENESIS_URL=https://operator-public.s3.us-west-2.amazonaws.com/chain/mainnet/genesis.json

# ========================================
# Usage Examples
# ========================================
# Standard Chain (ROLLUP_CONFIG_URL + L1_BEACON):
#   - Set ROLLUP_CONFIG_URL
#   - Set OP_NODE_L1_BEACON
#   - Set OP_NODE_L1_ETH_RPC
#   - Comment out OP_NODE_NETWORK
#   - Leave ALTDA variables commented
#
# ALTDA Chain (ROLLUP_CONFIG_URL + ALTDA):
#   - Set ROLLUP_CONFIG_URL
#   - Set OP_NODE_L1_ETH_RPC
#   - Set OP_NODE_ALTDA_ENABLED=true
#   - Set OP_NODE_ALTDA_DA_SERVER
#   - L1_BEACON will be auto-ignored
#   - Comment out OP_NODE_NETWORK
#
# Superchain Standard (OP_NODE_NETWORK + L1_BEACON):
#   - Set OP_NODE_NETWORK
#   - Set GETH_OP_NETWORK (same value)
#   - Set OP_NODE_L1_ETH_RPC
#   - Set OP_NODE_L1_BEACON
#   - Comment out ROLLUP_CONFIG_URL
#   - Leave ALTDA variables commented
#
# Superchain + ALTDA (OP_NODE_NETWORK + ALTDA):
#   - Set OP_NODE_NETWORK
#   - Set GETH_OP_NETWORK (same value)
#   - Set OP_NODE_L1_ETH_RPC
#   - Set OP_NODE_ALTDA_ENABLED=true
#   - Set OP_NODE_ALTDA_DA_SERVER
#   - L1_BEACON will be auto-ignored
#   - Comment out ROLLUP_CONFIG_URL
#   - Optional: GETH_ROLLUP_SUPERCHAIN_UPGRADES=false

# ========================================
# Quick Start
# ========================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your chain's configuration
# 3. Start the node: docker-compose up -d
# 4. Check logs: docker-compose logs -f
#
# For more details, see:
# - README.md - Quick start guide
# - docs/FLAG_MAPPING.md - Flag to environment variable mapping
# - examples/*.env - Real chain configurations
