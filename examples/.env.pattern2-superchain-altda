# ========================================
# Pattern 2: OP_NODE_NETWORK with Alt-DA (Plasma DA)
# ========================================
# Representative: Cyber Mainnet
# Uses: OP_NODE_NETWORK + GETH_OP_NETWORK + ALTDA
# Superchain with ALTDA

# ========================================
# Docker Images
# ========================================
GETH_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-geth:v1.101605.0
NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.16.5

# ========================================
# GETH Configuration
# ========================================
GETH_SYNCMODE=full
GETH_GCMODE=archive
GETH_ROLLUP_SEQUENCERHTTP=https://cyber.alt.technology
GETH_STATICNODES='[]'
GETH_OP_NETWORK=cyber-mainnet

# ========================================
# OP-NODE Configuration
# ========================================
OP_NODE_L1_ETH_RPC=https://ethereum-rpc.publicnode.com
OP_NODE_P2P_STATIC=
OP_NODE_NETWORK=cyber-mainnet
OP_NODE_ALTDA_ENABLED=true
OP_NODE_ALTDA_DA_SERVER=https://cyber-mainnet-op-plasma-da-server.alt.technology

# ========================================
# Helper Variables
# ========================================
GENESIS_URL=https://operator-public.s3.us-west-2.amazonaws.com/cyber/mainnet/genesis.json
