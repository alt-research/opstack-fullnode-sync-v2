# ========================================
# Pattern 3: OP_NODE_NETWORK with Beacon Proxy (No Alt-DA)
# ========================================
# Representative: Swell Mainnet
# Uses: OP_NODE_NETWORK + GETH_OP_NETWORK + L1_BEACON
# Superchain with standard beacon

# ========================================
# Docker Images
# ========================================
GETH_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-geth:v1.101603.5
NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.16.3

# ========================================
# GETH Configuration
# ========================================
GETH_SYNCMODE=full
GETH_GCMODE=archive
GETH_ROLLUP_SEQUENCERHTTP=https://rpc.ankr.com/swell
GETH_STATICNODES='[]'
GETH_OP_NETWORK=swell-mainnet

# ========================================
# OP-NODE Configuration
# ========================================
OP_NODE_L1_ETH_RPC=https://ethereum-rpc.publicnode.com
OP_NODE_L1_BEACON=https://ethereum-beacon-api.publicnode.com
OP_NODE_P2P_STATIC=
OP_NODE_NETWORK=swell-mainnet

# ========================================
# Helper Variables
# ========================================
GENESIS_URL=https://operator-public.s3.us-west-2.amazonaws.com/swell/mainnet/genesis.json
