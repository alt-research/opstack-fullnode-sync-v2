# ========================================
# Pattern 4: Alt-DA with EigenDA or Custom DA Service
# ========================================
# Representative: OpenLedger Mainnet
# Uses: ROLLUP_CONFIG_URL + ALTDA + DA_SERVICE
# ALTDA with service provider

# ========================================
# Docker Images
# ========================================
GETH_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-geth:v1.101411.0
NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.10.2

# ========================================
# GETH Configuration
# ========================================
GETH_SYNCMODE=full
GETH_GCMODE=archive
GETH_ROLLUP_SEQUENCERHTTP=https://openledger-rpc.alt.technology
GETH_STATICNODES='[]'

# ========================================
# OP-NODE Configuration
# ========================================
OP_NODE_L1_ETH_RPC=https://ethereum-rpc.publicnode.com
OP_NODE_P2P_STATIC=
OP_NODE_ALTDA_ENABLED=true
OP_NODE_ALTDA_DA_SERVER=https://openledger-mainnet-eigenda-proxy:3100
OP_NODE_ALTDA_DA_SERVICE=true

# ========================================
# Helper Variables
# ========================================
GENESIS_URL=https://operator-public.s3.us-west-2.amazonaws.com/openledger/mainnet/genesis.json
ROLLUP_CONFIG_URL=https://operator-public.s3.us-west-2.amazonaws.com/openledger/mainnet/rollup.json
