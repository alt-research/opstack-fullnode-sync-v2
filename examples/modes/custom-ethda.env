# ========================================
# Mode: Custom + Beacon
# ========================================
# Non-superchain chain using rollup/genesis files and L1 Beacon API.

RETH_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-reth:v1.11.0
NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.16.7

GENESIS_URL=https://replace-with-chain/genesis.json
ROLLUP_CONFIG_URL=https://replace-with-chain/rollup.json

RETH_CHAIN=/data/genesis.json
RETH_ROLLUP_SEQUENCER_HTTP=https://replace-with-sequencer-rpc.example
RETH_BOOTNODES=enode://replace-with-reth-bootnode@host:30303

OP_NODE_ROLLUP_CONFIG=/data/rollup.json
OP_NODE_L1_ETH_RPC=https://replace-with-l1-rpc.example
OP_NODE_L1_RPC_KIND=standard
OP_NODE_L1_TRUST_RPC=true
OP_NODE_L1_RPC_RATE_LIMIT=1000
OP_NODE_VERIFIER_L1_CONFS=15
OP_NODE_L1_BEACON=https://replace-with-l1-beacon.example
OP_NODE_SYNCMODE=consensus-layer
OP_NODE_P2P_STATIC=/dns/replace-with-fullnode-static-peer/tcp/9003/p2p/16Uiu2...
OP_NODE_LOG_LEVEL=INFO
OP_NODE_SEQUENCER_ENABLED=false
